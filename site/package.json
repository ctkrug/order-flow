{
  "name": "order-flow-site",
  "version": "0.1.0",
  "private": true,
  "description": "D3 front end for Order Flow, wired to the WASM matching engine",
  "type": "module",
  "scripts": {
    "predev": "bash ../engine/build-wasm.sh",
    "dev": "vite",
    "prebuild": "bash ../engine/build-wasm.sh",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
